# ─────────────────────────────────────────────────────────────────────────────
# SPBSP Ahilyanagar — backend environment configuration
#
# Copy this file to backend/.env and fill in the values for each environment.
# Nothing below is read from code — only from env. Moving to production is
# just: edit values here, restart, done.
#
# Every integration has an is_configured() check in backend/config.py. Leaving
# a section blank means that channel silently no-ops (logged, never crashes).
# ─────────────────────────────────────────────────────────────────────────────


# ── Core ─────────────────────────────────────────────────────────────────────
ENV=development                               # development | test | production
SECRET_KEY=                                   # REQUIRED in production (long random string)
DATABASE_URL=sqlite:///./pitham.db            # or mysql+pymysql://user:pass@host/db
FRONTEND_URL=http://localhost:3000            # used for email links & OAuth redirects
SQL_ECHO=false                                # true = echo all SQL (dev only)
ADMIN_RATE_LIMIT_PER_MIN=120                  # per-IP throttle on /admin/*


# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail example: create an app password at myaccount.google.com/apppasswords.
# If MAIL_USERNAME/PASSWORD are blank, all emails are logged as "EMAIL (stub)"
# and not actually sent — safe for dev.
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=                                     # defaults to MAIL_USERNAME if blank
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587


# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Setup:  developers.facebook.com → Create App → Add WhatsApp product
# Get these from the App Dashboard → WhatsApp → API Setup:
WHATSAPP_ACCESS_TOKEN=                         # long-lived token (System User token for prod)
WHATSAPP_PHONE_NUMBER_ID=                      # the ID of YOUR business number
WHATSAPP_API_VERSION=v22.0                     # bump when Meta releases newer graph API
# Approved template for booking confirmations (required OUTSIDE the 24h window).
# Leave blank to use free-form text (only works to test numbers + in 24h window).
WHATSAPP_DEFAULT_TEMPLATE=
WHATSAPP_DEFAULT_TEMPLATE_LANG=en


# ── SMS (provider-agnostic webhook) ──────────────────────────────────────────
# Any provider that accepts JSON POST {to, message} works.
# Examples:
#   MSG91:   SMS_PROVIDER_URL=https://api.msg91.com/api/v5/flow/
#            SMS_AUTH_HEADER=authkey: YOUR_KEY
#   Twilio:  use your own relay that forwards to Twilio's TwiML API
#   Gupshup: SMS_PROVIDER_URL=https://api.gupshup.io/sm/api/v1/msg
SMS_PROVIDER_URL=
SMS_AUTH_HEADER=
SMS_SENDER_ID=                                 # optional DLT-approved sender ID


# ── Google Sign-In ───────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth Client ID (Web)
GOOGLE_CLIENT_ID=


# ── PhonePe (Payments) ───────────────────────────────────────────────────────
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=sandbox                            # sandbox | production
PHONEPE_CALLBACK_USERNAME=                     # webhook auth (set in PhonePe dashboard)
PHONEPE_CALLBACK_PASSWORD=


# ── Zoom ─────────────────────────────────────────────────────────────────────
# Server-to-Server OAuth app at marketplace.zoom.us
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_TIMEZONE=Asia/Kolkata


# ── Sentry (error tracking) ──────────────────────────────────────────────────
# https://sentry.io → Projects → Backend → DSN
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1                         # 0.0 – 1.0, sample rate for perf traces


# ── Storage ──────────────────────────────────────────────────────────────────
# Local: files saved under backend/uploads/. Survives only if the dir is
# persistent (volume mount). On serverless / immutable containers, USE S3.
STORAGE_DRIVER=local                           # local | s3
LOCAL_UPLOAD_DIR=uploads

# S3 / S3-compatible (Cloudflare R2 recommended — zero egress fees):
S3_BUCKET=
S3_REGION=auto                                 # auto for R2; e.g. ap-south-1 for AWS Mumbai
S3_ENDPOINT_URL=                               # blank = AWS default; for R2: https://<acct>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=                            # public URL or CDN (e.g. https://<bucket>.<acct>.r2.dev)
